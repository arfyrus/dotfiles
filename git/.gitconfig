# This is Git's per-user configuration file.
[user]
# Please adapt and uncomment the following lines:
 	name = Arif Hafeez
	email = arif.hafeez@icloud.com
[core]
	autocrlf = input
	editor = nvim
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
